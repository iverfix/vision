{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 3,
    "patch": 4
  },
  "configurePresets": [
    {
      "name": "release-base",
      "displayName": "Release base",
      "generator": "Ninja",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "relWithDebInfo",
      "displayName": "Conan Release With Debug",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/conan/RelWithDebInfo/conan_toolchain.cmake"
      }
    },
    {
      "name": "release",
      "displayName": "Conan Release Base",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/conan/Release/conan_toolchain.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 0
    },
    {
      "name": "relWithDebInfo",
      "configurePreset": "relWithDebInfo",
      "jobs": 0
    }
  ]
}
