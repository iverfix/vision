{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 3,
    "patch": 4
  },
  "configurePresets": [
    {
      "name": "clang-ninja-base",
      "displayName": "Base configuration",
      "generator": "Ninja",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MESSAGE_LOG_LEVEL": "WARNING"
      }
    },
    {
      "name": "relWithDebInfo",
      "displayName": "RelWithDebInfo Configuration",
      "inherits": "clang-ninja-base",
      "binaryDir": "${sourceDir}/build/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/conan/RelWithDebInfo/conan_toolchain.cmake"
      }
    },
    {
      "name": "release",
      "displayName": "Release Configuration",
      "inherits": "clang-ninja-base",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/conan/Release/conan_toolchain.cmake"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Configuration",
      "inherits": "clang-ninja-base",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/conan/Debug/conan_toolchain.cmake"
      }
    },
    {
      "name": "cppcheck",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_CPPCHECK": "cppcheck;--enable=all;--inconclusive;--suppress=missingIncludeSystem;--std=c++26"
      }
    },
    {
      "name": "clang-tidy",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy"
      }
    },
    {
      "name": "iwyu",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_INCLUDE_WHAT_YOU_USE": "include-what-you-use"
      }
    },
    {
      "name": "ci-configure",
      "displayName": "Base configuration",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MESSAGE_LOG_LEVEL": "WARNING",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/conan/Release/conan_toolchain.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 0
    },
    {
      "name": "relWithDebInfo",
      "configurePreset": "relWithDebInfo",
      "jobs": 0
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 0
    },
    {
      "name": "cppcheck",
      "configurePreset": "cppcheck",
      "jobs": 0
    },
    {
      "name": "clang-tidy",
      "configurePreset": "clang-tidy",
      "jobs": 0
    },
    {
      "name": "iwyu",
      "configurePreset": "iwyu",
      "jobs": 0
    },
    {
      "name": "ci-build",
      "configurePreset": "ci-configure",
      "jobs": 0
    }
  ],
  "workflowPresets": [
    {
      "name": "release",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        }
      ]
    },
    {
      "name": "relWithDebInfo",
      "steps": [
        {
          "type": "configure",
          "name": "relWithDebInfo"
        },
        {
          "type": "build",
          "name": "relWithDebInfo"
        }
      ]
    },
    {
      "name": "debug",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        }
      ]
    },
    {
      "name": "cppcheck",
      "steps": [
        {
          "type": "configure",
          "name": "cppcheck"
        },
        {
          "type": "build",
          "name": "cppcheck"
        }
      ]
    },
    {
      "name": "clang-tidy",
      "steps": [
        {
          "type": "configure",
          "name": "clang-tidy"
        },
        {
          "type": "build",
          "name": "clang-tidy"
        }
      ]
    },
    {
      "name": "iwyu",
      "steps": [
        {
          "type": "configure",
          "name": "iwyu"
        },
        {
          "type": "build",
          "name": "iwyu"
        }
      ]
    },
    {
      "name": "ci-pipeline",
      "steps": [
        {
          "type": "configure",
          "name": "ci-configure"
        },
        {
          "type": "build",
          "name": "ci-build"
        }
      ]
    }
  ]
}
